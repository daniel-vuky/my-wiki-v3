# Postgres
POSTGRES_USER=folio
POSTGRES_PASSWORD=change-me
POSTGRES_DB=folio
DATABASE_URL=postgres://folio:change-me@db:5432/folio

# Redis
REDIS_URL=redis://redis:6379

# Ports
# WEB_PORT is the only HOST port published (point your reverse proxy / Cloudflare
# tunnel at it). Change it to avoid clashes with other projects on the server.
WEB_PORT=8080
# API_PORT is the api's internal listen port (also used by nginx to reach it).
# It is NOT published to the host, so it won't collide with other projects.
API_PORT=3000

# API
SESSION_SECRET=change-me-32-bytes-min
# Public origin the app is served from (used for the OAuth redirect URI and
# cookie security). For local use: http://localhost:8080. Behind your own
# Cloudflare tunnel / reverse proxy, set this to your public https domain.
PUBLIC_BASE_URL=http://localhost:8080
ALLOWED_EMAILS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
